# --- Production domain (Vercel) ---
# In Vercel → Project → Settings → Domains: add esimseeker.com (and www → redirect to apex if preferred).
# Set this to the public URL so metadata, sitemap, and server-side fetches use the correct origin.
NEXT_PUBLIC_SITE_URL=https://esimseeker.com

# Sister brand footer link (SeatSeekerLink); falls back if unset
NEXT_PUBLIC_SEATSEEKER_URL=https://seats.aero

# Outbound affiliate / tracking base for plan CTAs (path or full URL)
NEXT_PUBLIC_AFFILIATE_BASE_URL=/go

# Vercel Cron: same value in Vercel → Environment Variables. Cron requests use:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Supabase (Postgres + pgvector)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional server-only alias for URL (used if NEXT_PUBLIC_* is unset)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# eSIM Go API (catalogue sync — see lib/esim-go.ts)
ESIM_GO_API_KEY=
# Optional override; default is https://api.esim-go.com/v2.1
ESIM_GO_API_BASE_URL=
